<Window x:Class="TextEditorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TextEditorApp"
        mc:Ignorable="d"
        Title="Текстовый редактор" Height="450" Width="800">

    <Window.Resources>
        <!-- Описание стиля для кнопок выбора режима -->
        <Style x:Key="EditMode-ToggleButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="20, 0, 0, 0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- Состояние при наведении курсора -->
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <!-- Состояние при нажатии -->
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1, 1, 1, 1"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="LightGray">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                BorderBrush="DimGray" 
                BorderThickness="0, 0, 0, 2" 
                Padding="0, 5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <ToggleButton Content="Ж" 
                              FontWeight="Bold"
                              Style="{StaticResource EditMode-ToggleButton}" 
                              Click="ToggleButtonBold_Click"/>
                <ToggleButton Content="К"
                              FontStyle="Italic"
                              Style="{StaticResource EditMode-ToggleButton}" 
                              Click="ToggleButtonItalic_Click"/>
                <ToggleButton Style="{StaticResource EditMode-ToggleButton}" 
                              Click="ToggleButtonUnderline_Click">
                    <TextBlock Text="Ч" TextDecorations="Underline"/>
                </ToggleButton>
                <ToggleButton Style="{StaticResource EditMode-ToggleButton}" 
                              Margin="45, 0, 0, 0"
                              Click="ToggleButtonSubscript_Click"
                              x:Name="togBtnSub">
                    <TextBlock LineStackingStrategy="BlockLineHeight" >
                        X<Run BaselineAlignment="Subscript" FontSize="8">2</Run>
                    </TextBlock>
                </ToggleButton>
                <ToggleButton Style="{StaticResource EditMode-ToggleButton}" 
                              Click="ToggleButtonSuperscript_Click"
                              x:Name="togBtnSup">
                    <TextBlock LineStackingStrategy="BlockLineHeight">
                        X<Run BaselineAlignment="Superscript" FontSize="8">2</Run>
                    </TextBlock>
                </ToggleButton>
                <ToggleButton Content="S" 
                              Style="{StaticResource EditMode-ToggleButton}"
                              Margin="45, 0, 0, 0"
                              Click="ToggleButtonAlignmentStart_Click"
                              x:Name="togBtnStart"
                              />
                <ToggleButton Content="C" 
                              Style="{StaticResource EditMode-ToggleButton}"
                              Click="ToggleButtonAlignmentCenter_Click"
                              x:Name="togBtnCenter"
                              />
                <ToggleButton Content="E" 
                              Style="{StaticResource EditMode-ToggleButton}"
                              Click="ToggleButtonAlignmentEnd_Click"
                              x:Name="togBtnEnd"
                              />
                <ToggleButton Content="J" 
                              Style="{StaticResource EditMode-ToggleButton}"
                              Click="ToggleButtonAlignmentJustify_Click"
                              x:Name="togBtnJustify"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1">
            <RichTextBox x:Name="rtb" SelectionChanged="RichTextBox_SelectionChanged"/>
        </Border>
    </Grid>
</Window>